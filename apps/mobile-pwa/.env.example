# ── Mnemo Frontend Environment Variables ──────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Your FastAPI backend URL (no trailing slash)
# Local dev: http://127.0.0.1:8000
# Production: https://your-service.onrender.com
VITE_API_URL=http://127.0.0.1:8000

# Google OAuth Client ID from Google Cloud Console
# Must have JavaScript origin set to http://localhost:5173 (dev) AND your Vercel domain
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
