"""
Mnemo API — "Bring Your Own Storage" Edition
=============================================
All highlights are stored in a single `mnemo_vault.json` file in the user's
Google Drive appDataFolder (a hidden, app-specific space that never clutters
their Drive and is included in Google Takeout backups).

Every endpoint is fully stateless: the caller's Google access_token arrives
in the `Authorization: Bearer <token>` header, and the backend uses it to
read/write their personal vault on Drive.  No SQLite, no disk state.

Drive file layout (appDataFolder):
  └── mnemo_vault.json
        {
          "version": 1,
          "highlights": [
            {
              "id":         "<sha-256 fingerprint>",
              "book_title": "DUNE",
              "author":     "Frank Herbert",
              "content":    "...",
              "added_on":   "...",
              "source":     "kindle" | "playbooks" | "drive" | "manual"
            },
            ...
          ]
        }
"""

import hashlib
import io
import json
import re
from contextlib import asynccontextmanager
from datetime import datetime
from typing import List, Optional

from fastapi import Depends, FastAPI, File, Header, HTTPException, UploadFile
from fastapi.middleware.cors import CORSMiddleware
from googleapiclient.discovery import build
from googleapiclient.errors import HttpError
from googleapiclient.http import MediaIoBaseUpload
from google.oauth2.credentials import Credentials
from pydantic import BaseModel


# ─── Constants ────────────────────────────────────────────────────────────────

VAULT_FILENAME = "mnemo_vault.json"
EMPTY_VAULT    = {"version": 1, "highlights": []}


# ─── Google Drive helpers ──────────────────────────────────────────────────────

def _drive(access_token: str):
    """Build a Drive v3 service object from a short-lived access token."""
    creds = Credentials(token=access_token)
    return build("drive", "v3", credentials=creds, cache_discovery=False)


def _find_vault_id(service) -> Optional[str]:
    """Return the Drive file-id of mnemo_vault.json, or None if absent."""
    res = service.files().list(
        spaces="appDataFolder",
        q=f"name='{VAULT_FILENAME}' and trashed=false",
        fields="files(id)",
        pageSize=1,
    ).execute()
    files = res.get("files", [])
    return files[0]["id"] if files else None


def read_vault(access_token: str) -> dict:
    """
    Download and parse the user's vault from Drive.
    Returns EMPTY_VAULT (not an error) if the file doesn't exist yet —
    the first write will create it.
    """
    try:
        service  = _drive(access_token)
        file_id  = _find_vault_id(service)
        if not file_id:
            return dict(EMPTY_VAULT)          # first-time user
        raw = service.files().get_media(fileId=file_id).execute()
        # get_media() returns bytes
        text = raw.decode("utf-8") if isinstance(raw, bytes) else raw
        return json.loads(text)
    except HttpError as e:
        if e.resp.status == 401:
            raise HTTPException(status_code=401, detail="Google token expired or invalid.")
        raise HTTPException(status_code=502, detail=f"Drive read error: {e}")


def write_vault(access_token: str, vault: dict) -> None:
    """
    Serialise `vault` to JSON and upload it to Drive, overwriting the
    existing file or creating a new one.
    """
    try:
        service  = _drive(access_token)
        file_id  = _find_vault_id(service)
        payload  = json.dumps(vault, ensure_ascii=False, indent=2).encode("utf-8")
        media    = MediaIoBaseUpload(io.BytesIO(payload), mimetype="application/json")

        if file_id:
            service.files().update(
                fileId=file_id,
                media_body=media,
            ).execute()
        else:
            service.files().create(
                body={"name": VAULT_FILENAME, "parents": ["appDataFolder"]},
                media_body=media,
                fields="id",
            ).execute()
    except HttpError as e:
        if e.resp.status == 401:
            raise HTTPException(status_code=401, detail="Google token expired or invalid.")
        raise HTTPException(status_code=502, detail=f"Drive write error: {e}")


# ─── Auth dependency ───────────────────────────────────────────────────────────

async def get_token(authorization: str = Header(...)) -> str:
    """
    Extract the Bearer token from the Authorization header.
    All endpoints depend on this — unauthenticated requests are rejected.
    """
    if not authorization.startswith("Bearer "):
        raise HTTPException(
            status_code=401,
            detail="Authorization header must be 'Bearer <google_access_token>'",
        )
    return authorization[7:].strip()


# ─── Text-processing utilities (unchanged from original) ──────────────────────

def normalize_title(raw: str) -> str:
    if not raw:
        return "Stray Thoughts"
    clean = raw.upper().strip()
    clean = re.split(r'\s+-\s+|\s+BY\s+', clean)[0]
    clean = re.sub(r'\([^)]*\)', '', clean)
    return clean.strip() or "Stray Thoughts"


def fingerprint(title: str, content: str) -> str:
    raw = f"{title}::{content.strip()}"
    return hashlib.sha256(raw.encode("utf-8")).hexdigest()


def _merge(vault: dict, new_items: List[dict]) -> int:
    """
    Append items whose `id` doesn't already exist in the vault.
    Returns the count of items actually added.
    """
    existing_ids = {h["id"] for h in vault["highlights"]}
    added = 0
    for item in new_items:
        if item["id"] not in existing_ids:
            vault["highlights"].append(item)
            existing_ids.add(item["id"])
            added += 1
    return added


def parse_kindle_text(raw_text: str) -> List[dict]:
    """Parse 'My Clippings.txt' from a Kindle USB export."""
    items   = []
    blocks  = raw_text.split("==========")
    for block in blocks:
        lines = [l.strip() for l in block.strip().split("\n") if l.strip()]
        if len(lines) < 3:
            continue
        title_line, meta_line = lines[0], lines[1]
        if "Highlight" not in meta_line:
            continue
        content   = " ".join(lines[2:])
        raw_title = title_line
        author    = "Unknown"
        if "(" in title_line and title_line.endswith(")"):
            parts     = title_line.rsplit("(", 1)
            raw_title = parts[0].strip()
            author    = parts[1].replace(")", "").strip()
        clean = normalize_title(raw_title)
        items.append({
            "id":         fingerprint(clean, content),
            "book_title": clean,
            "author":     author,
            "content":    content,
            "added_on":   meta_line,
            "source":     "kindle",
        })
    return items


def parse_playbooks_text(raw_text: str, raw_title: str, author: str) -> List[dict]:
    """Parse a plain-text export of a Google Play Books highlight doc."""
    clean         = normalize_title(raw_title)
    items         = []
    current_quote = []
    meta          = "Play Books Drive Sync"
    for line in raw_text.splitlines():
        line = line.strip()
        if not line:
            continue
        if line.startswith("Highlight") or line.startswith("Note"):
            if current_quote:
                content = " ".join(current_quote)
                items.append({
                    "id":         fingerprint(clean, content),
                    "book_title": clean,
                    "author":     author,
                    "content":    content,
                    "added_on":   meta,
                    "source":     "playbooks",
                })
                current_quote = []
            meta = line
        else:
            current_quote.append(line)
    if current_quote:
        content = " ".join(current_quote)
        items.append({
            "id":         fingerprint(clean, content),
            "book_title": clean,
            "author":     author,
            "content":    content,
            "added_on":   meta,
            "source":     "playbooks",
        })
    return items


# ─── App ──────────────────────────────────────────────────────────────────────

@asynccontextmanager
async def lifespan(app: FastAPI):
    # No DB to initialise — Drive is the database.
    yield

app = FastAPI(title="Mnemo API — BYOS Edition", lifespan=lifespan)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=False,
    allow_methods=["*"],
    allow_headers=["*"],
)


# ─── Pydantic models ──────────────────────────────────────────────────────────

class Highlight(BaseModel):
    id:         str
    book_title: str
    author:     str
    content:    str
    source:     Optional[str] = None


class HighlightCreate(BaseModel):
    book_title: Optional[str] = "Stray Thoughts"
    content:    str


class HighlightUpdate(BaseModel):
    content: str


class SourceRename(BaseModel):
    old_title: str
    new_title: str


# ─── Endpoints ────────────────────────────────────────────────────────────────

@app.get("/highlights/", response_model=List[Highlight])
def get_highlights(token: str = Depends(get_token)):
    vault = read_vault(token)
    return vault["highlights"]


@app.post("/highlights/", response_model=Highlight)
def create_highlight(data: HighlightCreate, token: str = Depends(get_token)):
    vault       = read_vault(token)
    clean_title = normalize_title(data.book_title or "Stray Thoughts")
    fp          = fingerprint(clean_title, data.content)
    timestamp   = f"Manual Entry — {datetime.now().strftime('%Y-%m-%d %H:%M')}"

    new_item = {
        "id":         fp,
        "book_title": clean_title,
        "author":     "Unknown",
        "content":    data.content,
        "added_on":   timestamp,
        "source":     "manual",
    }
    _merge(vault, [new_item])
    write_vault(token, vault)
    return new_item


@app.put("/highlights/{highlight_id}")
def update_highlight(
    highlight_id: str,
    data: HighlightUpdate,
    token: str = Depends(get_token),
):
    vault    = read_vault(token)
    updated  = False
    for h in vault["highlights"]:
        if h["id"] == highlight_id:
            h["content"] = data.content
            updated = True
            break
    if not updated:
        raise HTTPException(status_code=404, detail="Thought not found")
    write_vault(token, vault)
    return {"status": "updated"}


@app.delete("/highlights/{highlight_id}")
def delete_highlight(highlight_id: str, token: str = Depends(get_token)):
    vault    = read_vault(token)
    original = len(vault["highlights"])
    vault["highlights"] = [h for h in vault["highlights"] if h["id"] != highlight_id]
    if len(vault["highlights"]) == original:
        raise HTTPException(status_code=404, detail="Thought not found")
    write_vault(token, vault)
    return {"status": "burned"}


@app.put("/sources/rename")
def rename_source(data: SourceRename, token: str = Depends(get_token)):
    vault     = read_vault(token)
    clean_new = normalize_title(data.new_title)
    count     = 0
    for h in vault["highlights"]:
        if h["book_title"] == data.old_title:
            h["book_title"] = clean_new
            count += 1
    write_vault(token, vault)
    return {"status": f"renamed {count} fragments", "new_title": clean_new}


@app.post("/upload/clippings")
async def upload_clippings(
    file:  UploadFile = File(...),
    token: str        = Depends(get_token),
):
    """Accept a 'My Clippings.txt' upload; merge into the Drive vault."""
    if not (file.filename or "").endswith(".txt"):
        raise HTTPException(status_code=400, detail="Expected a .txt file")

    raw_bytes = await file.read()
    try:
        raw_text = raw_bytes.decode("utf-8-sig")
    except UnicodeDecodeError:
        raw_text = raw_bytes.decode("latin-1", errors="replace")

    items = parse_kindle_text(raw_text)
    vault = read_vault(token)
    added = _merge(vault, items)
    write_vault(token, vault)
    return {"status": "ok", "added": added}


@app.post("/sync/drive")
def sync_playbooks_from_drive(token: str = Depends(get_token)):
    """
    Scan the user's Drive for a 'Play Books Notes' folder, export every
    Google Doc inside it as plain text, parse the highlight blocks, and
    merge them (deduplicated) into the vault.
    """
    try:
        service = _drive(token)
    except Exception as e:
        raise HTTPException(status_code=502, detail=str(e))

    # 1. Find the Play Books Notes folder
    folder_res = service.files().list(
        q="mimeType='application/vnd.google-apps.folder' "
          "and name='Play Books Notes' and trashed=false",
        fields="files(id)",
        pageSize=5,
    ).execute()
    folders = folder_res.get("files", [])
    if not folders:
        return {"status": "No 'Play Books Notes' folder found in Drive.", "added": 0}

    folder_id = folders[0]["id"]

    # 2. List all Google Docs in that folder
    docs_res = service.files().list(
        q=f"'{folder_id}' in parents "
          "and mimeType='application/vnd.google-apps.document' and trashed=false",
        fields="files(id, name)",
        pageSize=100,
    ).execute()
    docs = docs_res.get("files", [])

    # 3. Parse and collect new items
    new_items = []
    for doc in docs:
        try:
            export = service.files().export(
                fileId=doc["id"], mimeType="text/plain"
            ).execute()
            raw_text = export.decode("utf-8", errors="replace") if isinstance(export, bytes) else str(export)
            parts     = doc["name"].split(" - ", 1)
            raw_title = parts[0].strip()
            author    = parts[1].strip() if len(parts) > 1 else "Unknown"
            new_items.extend(parse_playbooks_text(raw_text, raw_title, author))
        except Exception:
            continue   # skip docs that fail to export

    # 4. Read vault, merge, write back
    vault = read_vault(token)
    added = _merge(vault, new_items)
    if added > 0:
        write_vault(token, vault)

    return {"status": "sync complete", "added": added}
